CI_ENVIRONMENT = development

# Backend tetap jalan lokal, database bisa online.
app.baseURL = 'http://localhost:8080/'

database.default.hostname = your-db-host
database.default.database = your_db_name
database.default.username = your-db-user
database.default.password = your-db-pass
database.default.DBDriver = MySQLi
database.default.DBPrefix =
database.default.port = 3306
database.default.charset = utf8mb4
database.default.DBCollat = utf8mb4_general_ci

# Ubah true hanya kalau provider database online memang meminta SSL.
database.default.encrypt = false

CORS_ALLOWED_ORIGINS = http://localhost:5173
COURSEHUB_FRONTEND_URL = http://localhost:5173
COURSEHUB_APP_VERSION = 0.1.0-final-project
COURSEHUB_API_KEY = change-this-api-key

JWT_SECRET =
JWT_ISSUER = coursehub-backend
JWT_AUDIENCE = coursehub-frontend
JWT_TTL_SECONDS = 7200
